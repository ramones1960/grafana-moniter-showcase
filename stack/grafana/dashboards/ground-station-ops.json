      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "timescaledb"
          },
          "rawSql": "SELECT coalesce(sum(data_downlinked_mb),0) FROM passes WHERE aos > now() - interval '24 hours'",
          "rawQuery": true,
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
