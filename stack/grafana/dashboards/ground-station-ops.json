    {
      "id": 5,
      "title": "Predicted Passes (5 orbits)",
      "type": "stat",
      "datasource": {
        "type": "postgres",
        "uid": "timescaledb"
      },
      "gridPos": {
        "x": 19,
        "y": 0,
        "w": 5,
        "h": 5
