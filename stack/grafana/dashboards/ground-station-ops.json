      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "timescaledb"
          },
          "rawSql": "SELECT count(*) FROM predicted_passes WHERE sat='SAT-1' AND t_aos > now()",
          "rawQuery": true,
          "format": "table"
        }
