# ── Grafana ────────────────────────────────
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=admin
# 外部Webへ埋め込む場合は true（②フロントエンド集約のデモ用）
GF_ALLOW_EMBEDDING=false

# ── InfluxDB v2 (衛星テレメトリ) ───────────────
INFLUXDB_ORG=spaceops
INFLUXDB_BUCKET=telemetry
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=spaceops-admin
# Grafana / simulator が使う固定トークン（デモ用。本番では生成すること）
INFLUXDB_TOKEN=spaceops-demo-token-please-change

# ── TimescaleDB (地上局/ミッション台帳) ─────────
TIMESCALE_DB=missionops
TIMESCALE_USER=missionops
TIMESCALE_PASSWORD=missionops-pass

# ── Simulator ─────────────────────────────────
# テレメトリ送出間隔（秒）
SIM_INTERVAL_SEC=1.0
# シミュレーション時間の加速率（1.0=実時間, 60=1秒で1分進む）
SIM_TIME_SCALE=60.0
